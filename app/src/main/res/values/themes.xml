<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.Screener" parent="Theme.AppCompat.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/bg_main</item>
        <item name="colorAccent">@color/accent_cyan</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_main</item>
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.Screener.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
    </style>
</resources>
